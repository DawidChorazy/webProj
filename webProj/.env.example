# MONGODB_URI=mongodb+srv://dawidchorazy03_db_user:<db_password>@webproj.pggwwxt.mongodb.net/?appName=webProj
# MONGODB_DB_NAME=webProj
# MONGODB_STORAGE_COLLECTION=app_storage

